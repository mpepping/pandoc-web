# VCS
.git
.gitignore
.github

# Dependencies — installed fresh inside the image
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local secrets / config
.env
.env.*

# Build / runtime artifacts not needed in image
temp
*.log
coverage
.nyc_output

# Editor / OS cruft
.DS_Store
.vscode
.idea
*.swp

# Repo-only files not needed at runtime
README.md
Makefile
docker-compose.yml
Dockerfile*
.dockerignore
k8s-deployment.yaml
